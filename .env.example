# ─── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL password — set a strong value in production
POSTGRES_PASSWORD=change_me_in_production

# Anthropic API key — required for the support chatbot and agents
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional (defaults shown) ────────────────────────────────────────────────

POSTGRES_DB=supporthub
POSTGRES_USER=supporthub
NODE_ENV=production
PORT=3001
CORS_ORIGIN=http://localhost:80

# Frontend API URL — used by Vite build
VITE_API_URL=http://localhost:3001

# ─── Agents (local dev) ───────────────────────────────────────────────────────
# These are only needed if you run the PM or QA agents locally.
# They inherit ANTHROPIC_API_KEY from above.
